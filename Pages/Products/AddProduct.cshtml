@page
@model LocalSupermarketManagementSystem.Pages.Products.AddProductModel

<h2>Add Product</h2>

<form method="post">
    <div>
        <label>Name:</label>
        <input asp-for="Product.Name" />
    </div>

    <div>
        <label>Category:</label>
        <input asp-for="Product.Category" />
    </div>

    <div>
        <label>Price:</label>
        <input asp-for="Product.Price" type="number" step="0.01" />
    </div>

    <div>
        <label>Quantity:</label>
        <input asp-for="Product.Quantity" type="number" />
    </div>

    <button type="submit">Add Product</button>
</form>
